<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TaskFlow - Todo List App</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div class="header-content">
                <h1>✓ TaskFlow</h1>
                <p>Organize your tasks, boost your productivity</p>
            </div>
        </header>

        <!-- Main Content -->
        <main class="main">
            <!-- Input Section -->
            <section class="input-section">
                <div class="input-container">
                    <input 
                        type="text" 
                        id="taskInput" 
                        class="task-input" 
                        placeholder="Add a new task..."
                        autocomplete="off"
                    >
                    <button id="addBtn" class="add-btn">Add Task</button>
                </div>
                <div class="filter-buttons">
                    <button class="filter-btn active" data-filter="all">All</button>
                    <button class="filter-btn" data-filter="active">Active</button>
                    <button class="filter-btn" data-filter="completed">Completed</button>
                </div>
            </section>

            <!-- Stats Section -->
            <section class="stats-section">
                <div class="stat-item">
                    <span class="stat-label">Total Tasks:</span>
                    <span class="stat-value" id="totalCount">0</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Completed:</span>
                    <span class="stat-value completed" id="completedCount">0</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Remaining:</span>
                    <span class="stat-value active" id="remainingCount">0</span>
                </div>
            </section>

            <!-- Task List -->
            <section class="task-section">
                <div id="taskList" class="task-list">
                    <!-- Tasks will be rendered here -->
                    <div class="empty-state">
                        <div class="empty-icon">📝</div>
                        <p>No tasks yet. Add one to get started!</p>
                    </div>
                </div>
            </section>

            <!-- Clear Completed Section -->
            <section class="action-section">
                <button id="clearBtn" class="clear-btn" style="display: none;">
                    Clear Completed Tasks
                </button>
                <button id="deleteAllBtn" class="delete-all-btn" style="display: none;">
                    Delete All Tasks
                </button>
            </section>
        </main>

        <!-- Footer -->
        <footer class="footer">
            <p>Built with ❤️ | TaskFlow Todo App © 2024</p>
        </footer>
    </div>

    <script src="script.js"></script>
</body>
</html>
